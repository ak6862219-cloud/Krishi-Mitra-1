# ─── Krishi Mitra Backend — Environment Variables ─────────────────────────────
#
# Copy this file to .env and fill in your values.
# NEVER commit the real .env to git.

# ── Gemini ─────────────────────────────────────────────────────────────────────
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=https://aistudio.google.com/app/apikey

# ── ML Model ───────────────────────────────────────────────────────────────────
# Path to your trained .h5 file (relative to this folder)
MODEL_PATH=./model/krishi_disease_model.h5

# Set to "true" while your model is still training — the server will run
# fine and return random predictions so you can test the full pipeline.
USE_MOCK_MODEL=true

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=8000

# ── CORS — which frontend URLs are allowed to call this server ─────────────────
# Local dev: keep defaults. Production: set to your deployed frontend URL.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
